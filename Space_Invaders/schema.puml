@startuml
!theme plain

Enum EntityMove {
  - Normal
  - Left
  - Right
}

abstract class Entity {
  - protected int _health
  - protected int _speed
  - protected int _moveOrientation
  - protected Brush _brush
  - protected int _left_border
  - protected int _right_border
  - protected bool _shoot
  - protected EntityMove _movePosition
  - protected readonly Stopwatch _cooldownTimer
  - protected TimeSpan _cooldownDuration
}

enum EnemyType {
  - Normal
  - Fast
  - Armored
}

class Enemy {
  - public EnemyType _type
  - public int points
  - public int _shootChance
  - private bool shoot
  - private Random _shotRanom
  + public Enemy(EnemyType type)
  + public override void Update()
  + public override void Die()
}

class Player {
  - const int FIRE_TYPE
  - private int _max_helth
  - private bool _keyAPress
  - private bool _keyDPress
  - private GameForm _parentForm
  - private bool _hasShield
  - private bool _doubleShotActive
  - private bool _speedBoostActive
  - private Timer _speedBoostTimer
  - private Timer _doubleShotTimer
  - private Timer _shieldTimer
  - private int _originalSpeed
  - private float _speedBoostRemaining
  - private float _doubleShotRemaining
  - private float _shieldRemaining
  
  + public Player()
  + private void InitializePowerupTimers()
  + public void SetParentForm(GameForm form)
  + protected override void Init()
  + protected override void OnPaint(PaintEventArgs e)
  + public void PausePowerupTimers()
  + public void ResumePowerupTimers()
  + public void PlayerKeyUp(KeyEventArgs e)
  + public void PlayerKeyDown(KeyEventArgs e)
  + public override void TakeDamage(int amount)
  + public override void Die()
  
  + public void ActivateSpeedBoost(float duration)
  + private void UpdateSpeedBoost()
  + private void DeactivateSpeedBoost()
  + public void ActivateDoubleShot(float duration)
  + private void UpdateDoubleShot()
  + private void DeactivateDoubleShot()
  + public void ActivateShield(float duration)
  + private void UpdateShield()
  + private void DeactivateShield()
  + public void AddExtraLife()
}

abstract class Projectile {
  - protected int _speed
  - protected Brush _brush
  - protected bool _delete
  - protected GameForm _parentForm
  
  + public Projectile()
  + public void SetParentForm(GameForm form)
  + public void Update()
  + public void TestInteractWith(List<Entity> entities)
  + public void TestInteractWith(Entity entity)
  + protected void Draw(object sender, PaintEventArgs e)
  + private bool DotInRect(int x1, int y1, int x2, int y2, int px, int py)
  + private bool CheckIntersectsWith(Entity entity)
  + protected bool IsOutOfBounds()
  + protected abstract void IntersectsWith(Entity entity)
  + public bool Delete
}

enum PowerupType {
  - SpeedUp
  - DoubleShot
  - Shield
  - ExtraLife
}

class Powerup {
  - private PowerupType _bonus;
  - private float _duration;
  - private Label _iconLabel;
  
  + public Powerup()
  + protected Powerup(PowerupType bonus, int speed, int x, int y)
  + private void SetPowerupAppearance()
  + private float DurationBonus(PowerupType bonus)
  + protected override void IntersectsWith(Entity player)
  + private void Effect(Player player)
}

class Bullet {
  - private bool _isPlayerShoot
  - private int _damage
  
  + public Bullet(bool isPlayerShoot, int damage, int speed, int x, int y)
  + protected override void IntersectsWith(Entity entity)
}



class BaseForm {
  - protected Color _moveBackColor
  - protected Color _moveForeColor
  - protected Color _leaveBackColor
  - protected Color _leaveForeColor
  + protected virtual void button_MouseMove()
  + protected virtual void button_MouseLeave()
}

class MainMenuForm {
  + public MainMenuForm()
  + private void button1_Click(object sender, EventArgs e)
