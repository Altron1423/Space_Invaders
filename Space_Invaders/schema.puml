  + private void summon_enemy(int x, int y, EnemyType type)
}

class Program {
  + static void Main()
}



Entity --|> Player
Entity --|> Enemy

Projectile --|> Bullet
Projectile --|> Powerup

EntityMove ..0 Entity
EnemyType ...0 Enemy
PowerupType ...0 Powerup

Player 0..0 GameForm
Enemy ..0 GameForm
Bullet ..0 GameForm
Powerup ..0 GameForm

Program .....> MainMenuForm

BaseForm ----|> MainMenuForm
BaseForm ---|> ControleForm
BaseForm ---|> InfoForm
BaseForm ---|> DifficultForm
BaseForm ----|> GameForm
BaseForm ----|> GameOverForm

MainMenuForm <..> ControleForm
MainMenuForm <..> InfoForm
MainMenuForm <.> DifficultForm
GameForm <.> InfoForm
GameForm <.> ControleForm
GameForm .> DifficultForm
GameForm <.> GameOverForm
GameForm .> MainMenuForm
GameOverForm .> MainMenuForm



abstract ExampleA {
  - protected int x // поле
  + public void f() // метод
}
class ExampleB {
  
}
class ExampleC {
  - private ExampleB b
}

ExampleA --|> ExampleB: "  Наследование"
ExampleB .0 ExampleC: "  Использование типа"
ExampleC .> ExampleB: "  Переход в фоме"


@enduml